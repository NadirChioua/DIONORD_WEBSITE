# Copier ce fichier en .env.local et remplir les valeurs

# Email SMTP – pour recevoir les demandes de contact
# Exemple Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Créer un mot de passe d'application Google : https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_mot_de_passe_application

# Email destinataire des demandes de contact
CONTACT_EMAIL=contact@dionord.ma
